# LLM provider. All public catalog models route through OpenRouter.
OPENROUTER_API_KEY=
AGENT_SMITH_DEFAULT_MODEL=gpt-5.5

# Runtime HTTP and agent execution.
# Permission mode: default, read_only, accept_edits, or bypass.
AGENT_SMITH_HTTP_DOCS_ENABLED=true
AGENT_SMITH_DEFAULT_PERMISSION_MODE=default

# Optional web search providers for the built-in web_search tool
# AGENT_SMITH_WEB_SEARCH_PROVIDER can be tavily or brave. If unset, the first
# provider with credentials will be used.
AGENT_SMITH_WEB_SEARCH_PROVIDER=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Primary PostgreSQL datastore (matches docker-compose defaults)
AGENT_SMITH_POSTGRES_URL=postgresql+asyncpg://smith:smith@localhost:5432/agent_smith

# Managed file storage (local defaults match MinIO in docker/compose.yml).
# Production pilot uses private Cloudflare R2 with region=auto and path style=false.
# This is an explicit selection; MinIO is not an automatic fallback for R2/AWS.
AGENT_SMITH_S3_PROVIDER=minio
AGENT_SMITH_S3_ENDPOINT_URL=http://localhost:9000
AGENT_SMITH_S3_REGION=us-east-1
AGENT_SMITH_S3_BUCKET=agent-smith
AGENT_SMITH_S3_ACCESS_KEY_ID=smith
AGENT_SMITH_S3_SECRET_ACCESS_KEY=smithsmith
AGENT_SMITH_S3_PATH_STYLE=true
AGENT_SMITH_S3_PRESIGN_TTL_SECONDS=600
AGENT_SMITH_FILE_MAX_BYTES=52428800
AGENT_SMITH_ATTACHMENT_MAX_COUNT=8
AGENT_SMITH_ATTACHMENT_MAX_MATERIALIZED_BYTES=20971520
AGENT_SMITH_ATTACHMENT_READ_CONCURRENCY=4
AGENT_SMITH_FILE_PENDING_TTL_SECONDS=3600
AGENT_SMITH_FILE_DELETED_RETENTION_SECONDS=604800
AGENT_SMITH_FILE_PRINCIPAL_QUOTA_BYTES=5368709120
AGENT_SMITH_FILE_MAX_PENDING_UPLOADS=10
AGENT_SMITH_FILE_INIT_RATE_PER_MINUTE=30
AGENT_SMITH_FILE_COMPLETE_RATE_PER_MINUTE=60
AGENT_SMITH_FILE_AUDIT_RETENTION_SECONDS=7776000
AGENT_SMITH_FILE_MAINTENANCE_INTERVAL_SECONDS=300

# Durable document processing. The worker and HTTP server share Postgres and
# private object storage; Redis/RabbitMQ are not required for this pipeline.
AGENT_SMITH_FILE_PROCESSING_PIPELINE_VERSION=document-v1
AGENT_SMITH_FILE_PROCESSING_MAX_ATTEMPTS=5
AGENT_SMITH_FILE_PROCESSING_POLL_SECONDS=1
AGENT_SMITH_FILE_PROCESSING_LEASE_SECONDS=60
AGENT_SMITH_FILE_PROCESSING_HEARTBEAT_SECONDS=20
AGENT_SMITH_FILE_PROCESSING_TIMEOUT_SECONDS=600
AGENT_SMITH_ATTACHMENT_DOCUMENT_CONTEXT_MAX_TOKENS=32000

# Standalone Admin HTTP control plane.
AGENT_SMITH_ADMIN_POSTGRES_URL=postgresql+asyncpg://smith:smith@localhost:5432/agent_smith
AGENT_SMITH_ADMIN_HOST=127.0.0.1
AGENT_SMITH_ADMIN_PORT=8766
AGENT_SMITH_ADMIN_PUBLIC_ORIGIN=http://127.0.0.1:5174
AGENT_SMITH_ADMIN_COOKIE_SECURE=false
AGENT_SMITH_ADMIN_TRUSTED_PROXIES=
AGENT_SMITH_ADMIN_HTTP_DOCS_ENABLED=true
# Optional production build directory. Leave unset while Vite serves the UI in development.
AGENT_SMITH_ADMIN_UI_DIST=
# Encrypts identity-provider assertion secrets at rest — generate:
# poetry run python -c "from agent_smith.app.services.provider_auth import generate_identity_secrets_key; print(generate_identity_secrets_key())"
AGENT_SMITH_IDENTITY_SECRETS_KEY=

# Parent-app assertion auth for the fake HRIS dev client.
# Dev only: change this secret for any shared environment.
AGENT_SMITH_ASSERTION_AUDIENCE=agent-smith
AGENT_SMITH_TRUSTED_APPS_JSON={"hris-sandbox":{"alg":"HS256","keys":{"dev-v1":"dev-secret-change-me"},"allowedProviders":["hris-sandbox"]}}

# MCP credentials encryption (Postgres store) — generate:
# poetry run python -c "from agent_smith.infra.mcp.credentials import generate_mcp_credentials_key; print(generate_mcp_credentials_key())"
MCP_CREDENTIALS_KEY=
