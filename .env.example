# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local HTTP model switcher
AGENT_SMITH_TEST_MODEL=openai
AGENT_SMITH_TEST_OPENAI_MODEL=gpt-4o-mini
AGENT_SMITH_TEST_GEMMA_MODEL_ID=gemma4-e2b
AGENT_SMITH_TEST_GEMMA_UPSTREAM_MODEL=gemma4:e2b
AGENT_SMITH_TEST_GEMMA_BASE_URL=http://localhost:11434/v1
AGENT_SMITH_TEST_GEMMA_API_KEY=local

# Google has two supported auth modes:
# - Gemini API key: set GEMINI_API_KEY
# - Vertex AI service account: set GOOGLE_APPLICATION_CREDENTIALS, and optionally project/location
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Optional web search providers for the built-in web_search tool
# AGENT_SMITH_WEB_SEARCH_PROVIDER can be tavily or brave. If unset, the first
# provider with credentials will be used.
AGENT_SMITH_WEB_SEARCH_PROVIDER=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://smith:smith@localhost:5432/agent_smith

# Parent-app assertion auth for the fake HRIS dev client.
# Dev only: change this secret for any shared environment.
AGENT_SMITH_ASSERTION_AUDIENCE=agent-smith
AGENT_SMITH_TRUSTED_APPS_JSON={"hris-sandbox":{"alg":"HS256","keys":{"dev-v1":"dev-secret-change-me"},"allowedProviders":["hris-sandbox"]}}

# MCP credentials encryption (Postgres store) — generate: poetry run python -c "from agent_mcp.credentials import generate_mcp_credentials_key; print(generate_mcp_credentials_key())"
MCP_CREDENTIALS_KEY=
