# LLM provider. All public catalog models route through OpenRouter.
OPENROUTER_API_KEY=
AGENT_SMITH_DEFAULT_MODEL=gpt-5.5

# Optional web search providers for the built-in web_search tool
# AGENT_SMITH_WEB_SEARCH_PROVIDER can be tavily or brave. If unset, the first
# provider with credentials will be used.
AGENT_SMITH_WEB_SEARCH_PROVIDER=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Primary PostgreSQL datastore (matches docker-compose defaults)
AGENT_SMITH_POSTGRES_URL=postgresql+asyncpg://smith:smith@localhost:5432/agent_smith

# Admin control-plane auth for /api/admin/* routes.
# Authorization: Bearer <AGENT_SMITH_ADMIN_TOKEN>
# Dev only: change this secret for any shared environment.
AGENT_SMITH_ADMIN_TOKEN=dev-admin-token-change-me
# Encrypts identity-provider assertion secrets at rest — generate:
# poetry run python -c "from agent_smith.app.services.provider_auth import generate_identity_secrets_key; print(generate_identity_secrets_key())"
AGENT_SMITH_IDENTITY_SECRETS_KEY=

# Parent-app assertion auth for the fake HRIS dev client.
# Dev only: change this secret for any shared environment.
AGENT_SMITH_ASSERTION_AUDIENCE=agent-smith
AGENT_SMITH_TRUSTED_APPS_JSON={"hris-sandbox":{"alg":"HS256","keys":{"dev-v1":"dev-secret-change-me"},"allowedProviders":["hris-sandbox"]}}

# MCP credentials encryption (Postgres store) — generate: poetry run python -c "from agent_mcp.credentials import generate_mcp_credentials_key; print(generate_mcp_credentials_key())"
MCP_CREDENTIALS_KEY=
