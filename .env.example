# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google has two supported auth modes:
# - Gemini API key: set GEMINI_API_KEY
# - Vertex AI service account: set GOOGLE_APPLICATION_CREDENTIALS, and optionally project/location
GEMINI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://smith:smith@localhost:5432/agent_smith
